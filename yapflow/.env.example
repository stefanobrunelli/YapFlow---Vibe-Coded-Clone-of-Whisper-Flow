# PromptFlow Lite — Environment Variables
#
# Copy this file to .env.local for development overrides.
# In production, the API key is stored via macOS Keychain (safeStorage).
# NEVER commit your actual API key.

# Optional: override API key for development without using the Settings UI
# VITE_DEV_API_KEY=sk-your-key-here

# Electron build signing (for notarization — optional for local use)
# APPLE_ID=your@apple.id
# APPLE_ID_PASSWORD=your-app-specific-password
# APPLE_TEAM_ID=YOUR_TEAM_ID
