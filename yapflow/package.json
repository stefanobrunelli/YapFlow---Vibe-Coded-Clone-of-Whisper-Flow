{
  "name": "yapflow",
  "version": "0.1.0",
  "description": "Voice-to-prompt macOS desktop app — lightweight Wispr Flow alternative",
  "main": "./out/main/index.js",
  "author": {
    "name": "Your Name",
    "email": "your@email.com"
  },
  "homepage": ".",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:mac:unsigned": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p src/renderer/tsconfig.json"
  },
  "dependencies": {
    "@headlessui/react": "^2.1.0",
    "electron-store": "7.0.3",
    "nanoid": "3.3.7",
    "openai": "^4.47.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uiohook-napi": "^1.5.3"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
